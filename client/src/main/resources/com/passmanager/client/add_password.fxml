<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15.0" alignment="CENTER" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.passmanager.client.ui.AddPasswordController">
    
    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
    </padding>

    <Label text="Add New Password" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <GridPane hgap="10.0" vgap="10.0">
        <Label text="Website:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="websiteField" promptText="e.g. Google" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Username:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="usernameField" promptText="e.g. user@mail.com" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Password:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="2">
            <TextField fx:id="passwordField" promptText="Your password" HBox.hgrow="ALWAYS"/>
            <Button text="🎲" onAction="#generatePassword" style="-fx-cursor: hand;"/>
        </HBox>
    </GridPane>

    <HBox spacing="10.0" alignment="CENTER">
        <Button text="Save" onAction="#handleSave" prefWidth="80.0" 
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;"/>
        <Button text="Cancel" onAction="#handleCancel" prefWidth="80.0"/>
    </HBox>
    
</VBox>